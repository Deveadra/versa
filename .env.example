# --- Core ---
AERITH_ENV_PATH=
AERITH_MODE=text
AERITH_DB_PATH=./aerith.db
AERITH_MEMORY_TTL_DAYS=30
AERITH_IMPORTANCE_THRESHOLD=25
PROPOSER_ALLOW_FULL_FILE_OVERWRITE=true

# --- LLM ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- TTS / Voice ---
TTS_ENGINE=elevenlabs
AERITH_AUTO_SPEAK=0
AERITH_WAKE_WORD=aerith
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT=pcm_16000
PICOVOICE_API_KEY=

# --- Home Assistant (note: some code uses HA_URL, other uses HA_BASE_URL) ---
HA_BASE_URL=
HA_URL=http://homeassistant.local:8123/api
HA_TOKEN=

# --- Self-improve / dream-cycle ---
AERITH_SELF_IMPROVE_ENABLED=0
AERITH_REPO_ROOT=.
AERITH_LOGS_DIR=logs
AERITH_LEARNING_DIR=memory/learning
AERITH_REPORTS_DIR=memory/reports
AERITH_GIT_REMOTE=origin
AERITH_GIT_DEFAULT_BRANCH=main
AERITH_RUFF_ARGS=ruff --config pyproject.toml check .
AERITH_MYPY_ARGS=mypy --install-types --non-interactive
AERITH_PYTEST_COLLECT_ARGS=pytest -q --collect-only
AERITH_PERF_SAMPLE_SECONDS=5
AERITH_OPEN_MR_ON_ANY_FIX=1

# --- GitHub PR automation ---
GITHUB_TOKEN=
GITHUB_REPO=yourname/versa
GITHUB_DEFAULT_BRANCH=main
GITHUB_BOT_NAME=aerith-bot
GITHUB_BOT_EMAIL=aerith-bot@local
GITHUB_REMOTE_NAME=origin
GITHUB_SSH_KEY_FILE=
GITHUB_GPG_KEY_FILE=

# --- Embeddings / Vector backends ---
EMBEDDINGS_PROVIDER=sentence_transformers
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
AERITH_VECTOR_BACKEND=auto
AERITH_ALLOW_DB_FALLBACK_SCHEMA=0

# --- Qdrant (optional) ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=events

# --- Profile path ---
USER_PROFILE_PATH=config/user_profile.json
# Phase 0 monorepo local defaults (safe placeholders)
CORE_PORT=4000
AI_PORT=4010
WEB_PORT=3000
MCP_GATEWAY_PORT=4020

NODE_ENV=development
RUNTIME_MODE=local

DATABASE_URL=/workspace/versa/packages/database/data/versa.db
DATABASE_READ_URL=/workspace/versa/packages/database/data/versa.db
DATABASE_MIGRATIONS_PATH=/workspace/versa/packages/database/src/migrations

FEATURE_MEMORY_ENABLED=0
FEATURE_APPROVALS_ENABLED=0
FEATURE_SKILLS_ENABLED=0
FEATURE_WORKSPACES_ENABLED=0

MCP_ENABLED=0
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=4021

TELEMETRY_ENABLED=0
TELEMETRY_CONSOLE_ENABLED=1
TELEMETRY_OTLP_ENABLED=0
TELEMETRY_SERVICE_NAME=versa

BRIDGE_ENABLED=0
BRIDGE_CORE_URL=http://127.0.0.1:4000
BRIDGE_AI_URL=http://127.0.0.1:4010
BRIDGE_TIMEOUT_MS=4000
